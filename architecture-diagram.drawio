                </mxCell>
                <mxCell id="exec-eventbridge-rule-label" value="EventBridge Rule&#xa;(Status Change)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="414" y="953" width="120" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="exec-postprocessing" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#F78E04;gradientDirection=north;fillColor=#D05C17;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" parent="1" vertex="1">
                    <mxGeometry x="646" y="900" width="48" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="exec-postprocessing-label" value="PostprocessingLambda" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="620" y="953" width="100" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="exec-arrow-eb-post" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" parent="1" source="exec-eventbridge-rule" target="exec-postprocessing" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exec-arrow-eb-post-label" value="Trigger" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" parent="exec-arrow-eb-post" vertex="1" connectable="0">
                    <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
                        <mxPoint as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="exec-post-action" value="&lt;b&gt;Save Execution Result&lt;/b&gt;&#xa;&#xa;TargetExecutionsTable.PutItem:&#xa;  PK: &quot;acme-corp#daily-report&quot;&#xa;  SK: execution_id&#xa;  status: &quot;SUCCESS&quot;&#xa;  result: {...}&#xa;  logs_url: &quot;...&quot;&#xa;  timestamp: &quot;2026-01-15T09:00:00Z&quot;" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="750" y="890" width="150" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="exec-dynamodb-tables" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="180" width="58" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="exec-dynamodb-label" value="DynamoDB Tables" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="969" y="243" width="120" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="exec-dynamodb-list" value="• TenantMappingsTable&#xa;  (alias → target_id)&#xa;&#xa;• TargetsTable&#xa;  (target config &amp; ARN)&#xa;&#xa;• TargetExecutionsTable&#xa;  (execution history)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="954" y="270" width="150" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="exec-arrow-pre-db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;dashed=1;" parent="1" source="exec-step1" target="exec-dynamodb-tables" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exec-arrow-pre-db2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;dashed=1;" parent="1" source="exec-step2" target="exec-dynamodb-tables" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="780" y="333"/>
                            <mxPoint x="780" y="209"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="exec-dynamodb-executions" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#4D72F3;gradientDirection=north;fillColor=#3334B9;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="950" width="58" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="exec-arrow-post-db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;dashed=1;" parent="1" source="exec-post-action" target="exec-dynamodb-executions" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="exec-key-insight" value="&lt;b&gt;KEY INSIGHT: The Orchestrator Pattern&lt;/b&gt;&#xa;&#xa;The ExecutorStateMachine acts as the central orchestrator:&#xa;&#xa;1. &lt;b&gt;Abstraction Layer&lt;/b&gt;: Tenants use friendly aliases&#xa;   (&quot;email-sender&quot;), not ARNs. System resolves them.&#xa;&#xa;2. &lt;b&gt;Parameter Injection&lt;/b&gt;: Target defaults are merged&#xa;   with schedule-specific parameters automatically.&#xa;&#xa;3. &lt;b&gt;Type Polymorphism&lt;/b&gt;: Same input format works for&#xa;   Lambda, ECS, or Step Functions - routing is automatic.&#xa;&#xa;4. &lt;b&gt;Centralized Security&lt;/b&gt;: Only the State Machine has&#xa;   permission to invoke targets. API cannot bypass it.&#xa;&#xa;5. &lt;b&gt;Consistent Logging&lt;/b&gt;: All executions follow the same&#xa;   three-phase pattern with uniform result capture." style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="440" width="320" height="270" as="geometry"/>
                </mxCell>
                <mxCell id="exec-alias-example" value="&lt;b&gt;Why Aliases Matter&lt;/b&gt;&#xa;&#xa;Instead of:&#xa;  &quot;Run arn:aws:lambda:us-east-1:123...&quot;&#xa;&#xa;Tenants say:&#xa;  &quot;Run email-sender&quot;&#xa;&#xa;Benefits:&#xa;• Upgrade targets (v1 → v2) without&#xa;  changing all schedules&#xa;• Tenant-specific mappings&#xa;• Human-readable references" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1000" y="740" width="240" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="exec-flow-summary" value="&lt;b&gt;Execution Flow Summary&lt;/b&gt;&#xa;&#xa;EventBridge Scheduler&#xa;  ↓ (with tenant_id + alias + payload)&#xa;ExecutorStateMachine&#xa;  ↓ Phase 1: Preprocessing&#xa;    • Resolve alias → target_id&#xa;    • Get target config &amp; ARN&#xa;    • Merge payloads&#xa;  ↓ Phase 2: Execution&#xa;    • Route by target_type&#xa;    • Invoke target with merged payload&#xa;    • Capture result &amp; logs&#xa;  ↓ Phase 3: Postprocessing&#xa;    • EventBridge detects completion&#xa;    • Save to TargetExecutionsTable&#xa;    • Include logs URL for debugging" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="80" y="520" width="280" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="exec-retry-note" value="&lt;b&gt;Error Handling&lt;/b&gt;&#xa;&#xa;Preprocessing: 2 retries&#xa;with exponential backoff&#xa;&#xa;Execution: Wrapped in&#xa;Parallel state with Catch&#xa;for centralized error handling&#xa;&#xa;Postprocessing: EventBridge&#xa;auto-retries on failure" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="740" width="200" height="170" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="security-model" name="Security Model &amp; IAM Roles">
        <mxGraphModel dx="1149" dy="865" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1500" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="sec-title" value="Security Model - IAM Role Segregation &amp; Least Privilege" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="280" y="30" width="800" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-subtitle" value="How execution abstraction and scoped permissions create a secure multi-tenant architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2" parent="1" vertex="1">
                    <mxGeometry x="280" y="65" width="800" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="sec-role1-box" value="AppLambdaRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="80" y="120" width="390" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="sec-app-lambda" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#F78E04;gradientDirection=north;fillColor=#D05C17;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" parent="1" vertex="1">
                    <mxGeometry x="121" y="155" width="58" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="sec-app-lambda-label" value="AppLambda (FastAPI)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="90" y="218" width="120" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="sec-app-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&#xa;• DynamoDB CRUD on all 6 tables&#xa;• EventBridge Scheduler management&#xa;• Cognito user operations&#xa;• Secrets Manager read&#xa;• RedriveExecution on StateMachine&#xa;&#xa;&lt;b&gt;✗ CANNOT:&lt;/b&gt;&#xa;• Invoke target Lambdas&#xa;• Run ECS tasks&#xa;• Start Step Functions (targets)&#xa;&#xa;&lt;b&gt;WHY:&lt;/b&gt; API manages schedules&#xa;but never executes targets directly.&#xa;Forces all execution through&#xa;controlled orchestrator." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="220" y="150" width="210" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="sec-role2-box" value="EventBridgeSchedulerRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="490" y="120" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="sec-scheduler" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#FF4F8B;gradientDirection=north;fillColor=#BC1356;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;" parent="1" vertex="1">
                    <mxGeometry x="531" y="155" width="58" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="sec-scheduler-label" value="EventBridge Scheduler" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="500" y="218" width="120" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="sec-scheduler-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&#xa;• StartExecution on ExecutorStateMachine&#xa;  (and ONLY that specific state machine)&#xa;&#xa;&lt;b&gt;✗ CANNOT:&lt;/b&gt;• Everything else&#xa;&#xa;&lt;b&gt;WHY:&lt;/b&gt; Scheduler has minimal permissions.&#xa;Cannot access DynamoDB, invoke Lambdas,&#xa;or do anything except start the orchestrator.&#xa;Principle of least privilege in action." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="628" y="150" width="210" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="sec-role3-box" value="ExecutorStateMachineRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="890" y="120" width="380" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="sec-sfn" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#FF4F8B;gradientDirection=north;fillColor=#BC1356;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.step_functions;" parent="1" vertex="1">
                    <mxGeometry x="941" y="155" width="58" height="58" as="geometry"/>
                </mxCell>
                <mxCell id="sec-sfn-label" value="ExecutorStateMachine" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="910" y="218" width="120" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="sec-sfn-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&#xa;• Invoke helper Lambdas (3)&#xa;• Run ANY ECS task (native integration)&#xa;• Start ANY Step Functions (native)&#xa;• PassRole to ECS tasks&#xa;• X-Ray tracing&#xa;&#xa;&lt;b&gt;✗ CANNOT:&lt;/b&gt;&#xa;• Access DynamoDB directly&#xa;• Manage EventBridge schedules&#xa;• Invoke target Lambdas directly&#xa;&#xa;&lt;b&gt;WHY:&lt;/b&gt; Single execution authority.&#xa;Uses native integrations for ECS/SFN.&#xa;Delegates Lambda invocation to helper.&#xa;Only invoked through Scheduler." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="1050" y="150" width="210" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="sec-helpers-box" value="Helper Lambda Roles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="80" y="440" width="1190" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="sec-pre-role-box" value="PreprocessingLambdaRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="100" y="480" width="370" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="sec-pre-lambda" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#F78E04;gradientDirection=north;fillColor=#D05C17;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" parent="1" vertex="1">
                    <mxGeometry x="120" y="510" width="38" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="sec-pre-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&lt;br&gt;• GetItem on TargetsTable&lt;br&gt;• GetItem on TenantMappingsTable&lt;br&gt;- PutItem on TargetExecutionsTable&lt;br&gt;&lt;br&gt;&lt;b&gt;✗ CANNOT:&lt;/b&gt; Write to Targets/Tenants,&amp;nbsp;invoke functions, manage schedules&lt;br&gt;&lt;br&gt;&lt;b&gt;WHY:&lt;/b&gt; Read-only access to&amp;nbsp;resolve aliases and get config." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="170" y="505" width="240" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="sec-exec-role-box" value="LambdaExecutionHelperRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="490" y="480" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="sec-exec-lambda" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#F78E04;gradientDirection=north;fillColor=#D05C17;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" parent="1" vertex="1">
                    <mxGeometry x="531" y="510" width="38" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="sec-exec-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&lt;br&gt;• InvokeFunction on ANY Lambda&lt;br&gt;• DescribeLogStreams on CloudWatch&lt;br&gt;• FilterLogEvents on CloudWatch&lt;br&gt;&lt;br&gt;&lt;b&gt;✗ CANNOT:&lt;/b&gt; Access DynamoDB,&amp;nbsp;run ECS tasks, start Step Functions&lt;br&gt;&lt;br&gt;&lt;b&gt;WHY:&lt;/b&gt; ONLY handles Lambda targets.&amp;nbsp;ECS and Step Functions are executed&amp;nbsp;directly by StateMachineRole using&amp;nbsp;native AWS integrations." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="578" y="500" width="270" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="sec-post-role-box" value="PostprocessingLambdaRole" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=12;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="890" y="480" width="360" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="sec-post-lambda" value="" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;gradientColor=#F78E04;gradientDirection=north;fillColor=#D05C17;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" parent="1" vertex="1">
                    <mxGeometry x="910" y="510" width="38" height="38" as="geometry"/>
                </mxCell>
                <mxCell id="sec-post-permissions" value="&lt;b&gt;✓ CAN:&lt;/b&gt;&#xa;• PutItem on TargetExecutionsTable&#xa;• DescribeExecution on Step Functions&#xa;&#xa;&lt;b&gt;✗ CANNOT:&lt;/b&gt; Read other DynamoDB tables,&#xa;invoke functions, manage schedules, access targets&#xa;&#xa;&lt;b&gt;WHY:&lt;/b&gt; Write-only access to execution history.&#xa;Cannot modify schedules or invoke targets. Describes&#xa;executions to get full results for storage." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=9;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="970" y="500" width="270" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="sec-flow-diagram" value="Security Flow - Execution Path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="80" y="680" width="680" height="460" as="geometry"/>
                </mxCell>
                <mxCell id="sec-user-box" value="User/Schedule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="720" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-api-box" value="AppLambda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="780" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-scheduler-box" value="EventBridge&#xa;Scheduler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="840" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-sfn-box" value="Executor&#xa;StateMachine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="900" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-target-box" value="TARGET&#xa;(Lambda/ECS/SFN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="110" y="960" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="sec-user-box" target="sec-api-box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sec-arrow1-label" value="Request execution" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" parent="sec-arrow1" vertex="1" connectable="0">
                    <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
                        <mxPoint x="50" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="sec-api-box" target="sec-scheduler-box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sec-arrow2-label" value="Create schedule" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" parent="sec-arrow2" vertex="1" connectable="0">
                    <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
                        <mxPoint x="50" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="sec-scheduler-box" target="sec-sfn-box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sec-arrow3-label" value="StartExecution" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" parent="sec-arrow3" vertex="1" connectable="0">
                    <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
                        <mxPoint x="50" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="sec-sfn-box" target="sec-target-box" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sec-arrow4-label" value="Invoke target" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" parent="sec-arrow4" vertex="1" connectable="0">
                    <mxGeometry x="-0.1" y="1" relative="1" as="geometry">
                        <mxPoint x="50" as="offset"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-blocked1" value="✗" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=24;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="250" y="790" width="40" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-blocked1-label" value="BLOCKED:&#xa;API cannot invoke&#xa;targets directly" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="300" y="785" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="sec-blocked1-line" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="sec-api-box" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="210" y="800" as="sourcePoint"/>
                        <mxPoint x="250" y="975" as="targetPoint"/>
                        <Array as="points">
                            <mxPoint x="240" y="800"/>
                            <mxPoint x="240" y="975"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-blocked2" value="✗" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=24;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="250" y="850" width="40" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="sec-blocked2-label" value="BLOCKED:&#xa;Scheduler cannot invoke&#xa;targets directly" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="300" y="845" width="120" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="sec-blocked2-line" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" parent="1" source="sec-scheduler-box" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="210" y="860" as="sourcePoint"/>
                        <mxPoint x="250" y="980" as="targetPoint"/>
                        <Array as="points">
                            <mxPoint x="240" y="860"/>
                            <mxPoint x="240" y="980"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="sec-only-path" value="✓ ONLY VALID PATH" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="250" y="965" width="140" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="sec-flow-notes" value="&lt;b&gt;Security Guarantees:&lt;/b&gt;&#xa;&#xa;1. No component can bypass the orchestrator&#xa;2. User requests cannot directly invoke targets&#xa;3. API can create schedules but not execute&#xa;4. All execution flows through single audit point&#xa;5. Helper Lambdas have scoped, minimal permissions&#xa;6. State Machine is the ONLY execution authority" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="440" y="720" width="300" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="sec-abstraction-notes" value="&lt;b&gt;Execution Abstraction Benefits:&lt;/b&gt;&#xa;&#xa;1. &lt;b&gt;Single Point of Control:&lt;/b&gt; All executions&#xa;   go through StateMachine - easy to audit,&#xa;   monitor, and enforce policies.&#xa;&#xa;2. &lt;b&gt;Blast Radius Limitation:&lt;/b&gt; If API is&#xa;   compromised, attacker cannot invoke targets&#xa;   directly. Can only create schedules.&#xa;&#xa;3. &lt;b&gt;Three Execution Paths:&lt;/b&gt;&#xa;   • Lambda: via LambdaExecutionHelper&#xa;   • ECS: native Step Functions integration&#xa;   • Step Functions: native SFN integration&#xa;&#xa;4. &lt;b&gt;Easy Updates:&lt;/b&gt; Change execution logic&#xa;   in one place (StateMachine), not in every&#xa;   component that needs to invoke targets." style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="440" y="880" width="300" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="sec-principle-box" value="Principle of Least Privilege in Action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="800" y="680" width="470" height="460" as="geometry"/>
                </mxCell>
                <mxCell id="sec-principle-content" value="&lt;b&gt;What is Least Privilege?&lt;/b&gt;&#xa;Each component gets ONLY the permissions it needs to do its job,&#xa;and nothing more. This limits damage if a component is compromised.&#xa;&#xa;&lt;b&gt;How We Apply It:&lt;/b&gt;&#xa;&#xa;&lt;b&gt;1. AppLambda&lt;/b&gt; manages data and schedules but cannot execute.&#xa;   If compromised: Cannot invoke targets directly.&#xa;&#xa;&lt;b&gt;2. EventBridge Scheduler&lt;/b&gt; can only start ExecutorStateMachine.&#xa;   If compromised: Cannot access data or targets.&#xa;&#xa;&lt;b&gt;3. ExecutorStateMachine&lt;/b&gt; can execute but not manage schedules.&#xa;   If compromised: Cannot create persistent schedules.&#xa;&#xa;&lt;b&gt;4. PreprocessingLambda&lt;/b&gt; has read-only access to tables.&#xa;   If compromised: Cannot modify data or invoke anything.&#xa;&#xa;&lt;b&gt;5. LambdaExecutionHelper&lt;/b&gt; can invoke but not read data.&#xa;   If compromised: Needs to know exact ARN and payload.&#xa;&#xa;&lt;b&gt;6. PostprocessingLambda&lt;/b&gt; can only write execution results.&#xa;   If compromised: Cannot read other data or invoke targets.&#xa;&#xa;&lt;b&gt;Result:&lt;/b&gt; Compromising one component doesn&#39;t give access to the&#xa;entire system. Attacker would need to compromise multiple components&#xa;with different permissions to do serious damage." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="820" y="715" width="430" height="345" as="geometry"/>
                </mxCell>
                <mxCell id="sec-comparison-box" value="Comparison: Without Abstraction vs With Abstraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="90" y="1180" width="1180" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="sec-without-box" value="&lt;b&gt;❌ WITHOUT Execution Abstraction&lt;/b&gt;&#xa;(Dangerous Pattern)&#xa;&#xa;AppLambda needs permissions to:&#xa;• Invoke ALL target Lambdas (wildcard)&#xa;• Run ALL ECS tasks (wildcard)&#xa;• Start ALL Step Functions (wildcard)&#xa;&#xa;&lt;b&gt;Problem:&lt;/b&gt; If API is compromised,&#xa;attacker has full execution access to&#xa;entire AWS account. Single point of failure.&#xa;&#xa;&lt;b&gt;Audit:&lt;/b&gt; Hard to track who invoked what.&#xa;Execution scattered across components." style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="110" y="1220" width="350" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="sec-with-box" value="&lt;b&gt;✅ WITH Execution Abstraction&lt;/b&gt;&#xa;(Secure Pattern)&#xa;&#xa;AppLambda has NO execution permissions.&#xa;Only ExecutorStateMachine can execute.&#xa;&#xa;&lt;b&gt;Benefit:&lt;/b&gt; If API is compromised,&#xa;attacker can only create schedules.&#xa;Cannot invoke targets on demand.&#xa;&#xa;&lt;b&gt;Audit:&lt;/b&gt; All executions flow through&#xa;StateMachine. Single audit point.&#xa;Step Functions tracks full history.&#xa;&#xa;&lt;b&gt;Monitoring:&lt;/b&gt; Watch one IAM role&#xa;(StateMachineRole) for execution activity." style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="498" y="1220" width="350" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="sec-key-takeaway" value="&lt;b&gt;KEY TAKEAWAY&lt;/b&gt;&#xa;&#xa;By abstracting execution behind ExecutorStateMachine:&#xa;&#xa;1. Limit blast radius of compromises&#xa;2. Centralize security enforcement&#xa;3. Enable comprehensive audit trails&#xa;4. Simplify permission management&#xa;5. Prevent privilege escalation attacks&#xa;&#xa;The orchestrator pattern is more complex to build,&#xa;but provides much stronger security guarantees&#xa;than allowing direct execution permissions." style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=11;spacingLeft=10;spacingTop=10;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="890" y="1220" width="350" height="230" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="dr-failover" name="DR Failover Strategy">
        <mxGraphModel dx="2509" dy="1462" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="dr-title" value="Disaster Recovery Failover Strategy: US-East-1 → US-West-1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" parent="1" vertex="1">
                    <mxGeometry x="400" y="20" width="800" height="40" as="geometry"/>
                </mxCell>
