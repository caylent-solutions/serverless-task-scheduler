                <mxCell id="api-routes-box" value="FastAPI Routes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontSize=14;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="500" y="100" width="600" height="590" as="geometry"/>
                </mxCell>
                <mxCell id="auth-routes" value="&lt;b&gt;/api/auth&lt;/b&gt;&#xa;&#xa;POST /login&#xa;  → Cognito InitiateAuth&#xa;&#xa;POST /callback&#xa;  → Exchange code for tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="520" y="130" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="user-routes" value="&lt;b&gt;/api/user&lt;/b&gt;&#xa;&#xa;GET /info&#xa;  → UserMappingsTable (Query by user_id)&#xa;  → Returns tenants user can access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="520" y="250" width="250" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="targets-routes" value="&lt;b&gt;/api/targets&lt;/b&gt;&#xa;&#xa;GET / → TargetsTable (Scan)&#xa;GET /{id} → TargetsTable (GetItem)&#xa;POST / → TargetsTable (PutItem)&#xa;PUT /{id} → TargetsTable (UpdateItem)&#xa;DELETE /{id} → TargetsTable (DeleteItem)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="520" y="351" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="tenants-routes" value="&lt;b&gt;/api/tenants&lt;/b&gt;&#xa;&#xa;GET / → TenantsTable (Scan)&#xa;GET /{id} → TenantsTable (GetItem)&#xa;POST / → TenantsTable (PutItem)&#xa;PUT /{id} → TenantsTable (UpdateItem)&#xa;DELETE /{id} → TenantsTable (DeleteItem)&#xa;&#xa;GET /{id}/users&#xa;  → UserMappingsTable (Query GSI)&#xa;POST /{id}/users&#xa;  → UserMappingsTable (PutItem)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="520" y="480" width="250" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="mappings-routes" value="&lt;b&gt;/api/tenants/{id}/mappings&lt;/b&gt;&#xa;&#xa;GET / → TenantMappingsTable (Query)&#xa;GET /{alias} → TenantMappingsTable (GetItem)&#xa;POST / → TenantMappingsTable (PutItem)&#xa;DELETE /{alias} → TenantMappingsTable (DeleteItem)&#xa;&#xa;POST /{alias}/_execute&#xa;  → Create one-time EventBridge Schedule&#xa;  → Schedule triggers ExecutorStateMachine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="810" y="130" width="270" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="schedules-routes" value="&lt;b&gt;/api/tenants/{id}/mappings/{alias}/schedules&lt;/b&gt;&#xa;&#xa;GET / → SchedulesTable (Query by tenant_id)&#xa;GET /{schedule_id} → SchedulesTable (GetItem)&#xa;POST / → SchedulesTable (PutItem)&#xa;  + EventBridge Scheduler (CreateSchedule)&#xa;PUT /{schedule_id} → SchedulesTable (UpdateItem)&#xa;  + EventBridge Scheduler (UpdateSchedule)&#xa;DELETE /{schedule_id} → SchedulesTable (DeleteItem)&#xa;  + EventBridge Scheduler (DeleteSchedule)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="810" y="320" width="270" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="executions-routes" value="&lt;b&gt;/api/tenants/{id}/mappings/{alias}&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;/schedules/{sid}/executions&lt;/b&gt;&lt;br&gt;&lt;br&gt;GET /&lt;br&gt;  → TargetExecutionsTable&lt;br&gt;  → Query by tenant_schedule (PK)&lt;br&gt;&lt;br&gt;GET /{execution_id}&lt;br&gt;  → TargetExecutionsTable (GetItem)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="810" y="510" width="270" height="140" as="geometry"/>
