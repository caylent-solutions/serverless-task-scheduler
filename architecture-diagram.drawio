                <mxCell id="exec-arrow-sfn-choice-label" value="2. Route" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;labelBackgroundColor=none;" parent="exec-arrow-sfn-choice" vertex="1" connectable="0">
