                <mxCell id="exec-step1" value="&lt;b&gt;Step 1: Resolve Alias&lt;/b&gt;&#xa;&#xa;Query TenantMappingsTable:&#xa;  PK: tenant_id (&quot;acme-corp&quot;)&#xa;  SK: target_alias (&quot;email-sender&quot;)&#xa;&#xa;Returns:&#xa;  target_id: &quot;email-sender-v2&quot;" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
