                            <mxPoint x="1160" y="545"/>
                            <mxPoint x="1160" y="545"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="api-legend-box" value="Route Types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="279" y="60" width="180" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-auth" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
                    <mxGeometry x="299" y="100" width="20" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-auth-label" value="Auth &amp; User Routes" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="329" y="95" width="120" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-execution" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="299" y="140" width="20" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-execution-label" value="Execution Routes&#xa;(Schedules &amp; Mappings)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="329" y="130" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-history" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="299" y="190" width="20" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="api-legend-history-label" value="History/Read-Only&#xa;(Executions)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="329" y="180" width="120" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="api-http-methods" value="&lt;b&gt;HTTP Verbs Used:&lt;/b&gt;&#xa;&#xa;GET - Retrieve data (Query, GetItem, Scan)&#xa;POST - Create new resources (PutItem)&#xa;PUT - Update existing resources (UpdateItem)&#xa;DELETE - Remove resources (DeleteItem)&#xa;&#xa;&lt;b&gt;DynamoDB Operations:&lt;/b&gt;&#xa;&#xa;GetItem - Retrieve single item by PK (+ SK)&#xa;Query - Retrieve items by PK (+ optional SK prefix)&#xa;Scan - Retrieve all items (no filtering)&#xa;PutItem - Create/replace item&#xa;UpdateItem - Modify specific attributes&#xa;DeleteItem - Remove item" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="60" width="280" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="api-patterns" value="&lt;b&gt;Key Access Patterns:&lt;/b&gt;&#xa;&#xa;1. User logs in → Query UserMappingsTable&#xa;   to get allowed tenants&#xa;&#xa;2. Schedule CRUD → Update both SchedulesTable&#xa;   AND EventBridge Scheduler in sync&#xa;&#xa;3. Execute on-demand → Create one-time&#xa;   EventBridge Schedule (at: now + 1 min)&#xa;&#xa;4. View executions → Query by tenant_schedule&#xa;   or use GSI to filter by tenant_target" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="320" width="280" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="api-tenant-isolation" value="&lt;b&gt;Multi-Tenant Isolation:&lt;/b&gt;&#xa;&#xa;All DynamoDB tables use tenant_id as PK&#xa;or part of composite key. Every API call:&#xa;&#xa;1. Validates JWT token (Cognito)&#xa;2. Checks UserMappingsTable for access&#xa;3. Filters queries by tenant_id&#xa;4. Returns 403 if access denied" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1290" y="540" width="280" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="0179kwx2VH1OqDo1tQdi-2" style="edgeStyle=none;html=1;entryX=1;entryY=0.25;entryDx=0;entryDy=0;entryPerimeter=0;dashed=1;" parent="1" source="targets-routes" target="api-targets-table" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
