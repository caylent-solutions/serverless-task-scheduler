    <diagram id="api-breakdown" name="API Routes &amp; DynamoDB">
        <mxGraphModel dx="2509" dy="1462" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
            <root>
