                </mxCell>
                <mxCell id="exec-step3" value="&lt;b&gt;Step 3: Merge Payloads&lt;/b&gt;&#xa;&#xa;Merged payload = &#xa;  target.default_payload&#xa;  + schedule.payload&#xa;&#xa;Result:&#xa;{&#xa;  &quot;from&quot;: &quot;noreply@acme.com&quot;,&#xa;  &quot;template&quot;: &quot;default&quot;,&#xa;  &quot;recipient&quot;: &quot;boss@acme.com&quot;,&#xa;  &quot;report_type&quot;: &quot;sales&quot;&#xa;}" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
