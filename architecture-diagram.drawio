                </mxCell>
                <mxCell id="exec-step2" value="&lt;b&gt;Step 2: Get Target Config&lt;/b&gt;&#xa;&#xa;Query TargetsTable:&#xa;  PK: target_id (&quot;email-sender-v2&quot;)&#xa;&#xa;Returns:&#xa;  target_arn: &quot;arn:aws:lambda:...&quot;&#xa;  target_type: &quot;lambda&quot;&#xa;  default_payload: {&#xa;    &quot;from&quot;: &quot;noreply@acme.com&quot;,&#xa;    &quot;template&quot;: &quot;default&quot;&#xa;  }" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
