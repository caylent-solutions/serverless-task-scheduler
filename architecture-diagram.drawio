                </mxCell>
                <mxCell id="exec-trigger-content" value="EventBridge Scheduler sends:&#xa;&#xa;{&#xa;  &quot;tenant_id&quot;: &quot;acme-corp&quot;,&#xa;  &quot;target_alias&quot;: &quot;email-sender&quot;,&#xa;  &quot;schedule_id&quot;: &quot;daily-report&quot;,&#xa;  &quot;payload&quot;: {&#xa;    &quot;recipient&quot;: &quot;boss@acme.com&quot;,&#xa;    &quot;report_type&quot;: &quot;sales&quot;&#xa;  }&#xa;}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontFamily=Courier New;spacingLeft=10;" parent="1" vertex="1">
