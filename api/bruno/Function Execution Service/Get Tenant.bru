meta {
  name: Get Tenant
  type: http
  seq: 23
}

get {
  url: {{baseUrl}}/tenants/{{tenant_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

docs {
  ## Get Tenant Details

  Retrieves detailed information about a specific tenant.

  Users can only view tenants they have access to.
  Admin users can view all tenants.
}
