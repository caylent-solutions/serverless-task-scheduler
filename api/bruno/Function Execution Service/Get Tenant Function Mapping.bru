meta {
  name: Get Tenant Function Mapping
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/tenants/:tenant_id/mappings/:target_alias
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

params:path {
  tenant_id: my-tenant
  target_alias: my-function-alias
}

docs {
  Get a specific target mapping for a tenant. Requires authentication and tenant access.

  Returns details about a single function mapping by its alias.
}
