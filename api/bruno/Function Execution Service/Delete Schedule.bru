meta {
  name: Delete Schedule
  type: http
  seq: 15
}

delete {
  url: {{baseUrl}}/tenants/{{tenant_id}}/mappings/{{target_alias}}/schedules/{{schedule_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

docs {
  Delete a schedule. Requires authentication and tenant access.

  Removes the schedule from both EventBridge and DynamoDB.
}
