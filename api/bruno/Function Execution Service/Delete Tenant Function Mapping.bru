meta {
  name: Delete Tenant Function Mapping
  type: http
  seq: 11
}

delete {
  url: {{baseUrl}}/tenants/{{tenant_id}}/mappings/{{target_alias}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

docs {
  Delete a tenant target mapping. Requires authentication and tenant access.

  Removes the mapping between a tenant and a target function.
}
